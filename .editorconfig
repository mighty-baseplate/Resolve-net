# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# source files
[*.{ts,tsx,js,jsx,json}]
indent_style = space
indent_size = 2
max_line_length = 100

# markdown
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# yaml
[*.{yml,yaml}]
indent_style = space
indent_size = 2
